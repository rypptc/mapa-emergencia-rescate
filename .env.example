# Neon Postgres (Vercel Marketplace).
# Si conectas Neon desde Vercel, esta variable se inyecta sola.
# Para desarrollo local: vercel env pull .env.local
DATABASE_URL=

# OpenPanel analytics.
# NEXT_PUBLIC_OPENPANEL_CLIENT_ID comes from the OpenPanel project settings.
# OPENPANEL_API_URL should point to your self-hosted OpenPanel API, including /api.
# Example: https://openpanel.example.com/api
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
OPENPANEL_API_URL=
NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL=
NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST=terremotovenezuela.app

# Cabecera de confianza para extraer la IP del cliente en el rate-limit.
# Déjala vacía si tu plataforma pone `x-real-ip` (p. ej. Vercel). Con otro
# proxy/CDN, ponla a la cabecera NO falsificable (ej. cf-connecting-ip,
# x-vercel-forwarded-for). Nunca uses x-forwarded-for (el cliente la falsifica).
TRUSTED_IP_HEADER=

# Sal para hashear la IP del cliente antes de persistirla (columnas ip_hash).
# Genera una cadena aleatoria larga (p. ej. `openssl rand -hex 32`). NO la rotes
# sin migrar/backfill: cambia todos los hashes y rompe la dedup por IP.
IP_SALT=
