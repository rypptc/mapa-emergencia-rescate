# ============================================================================
# .env.example — contrato de variables de entorno del monorepo (frontend +
# backend + worker + infra). Copia a `.env` y rellena. `.env` está gitignored:
# NUNCA commitees secretos reales.
#
# Marcas:
#   [REQ]  obligatorio (el server hace fail-fast sin esto, o no arranca).
#   [REC]  recomendado (degrada con gracia si falta, pero deberías ponerlo).
#   [OPC]  opcional / override de un default sano.
#
# Dónde vive cada cosa en PROD:
#   - GH SECRET  → GitHub repo → Settings → Secrets (lo usa el workflow de deploy).
#   - GH VAR     → GitHub repo → Settings → Variables (no secreto; build-args).
#   - app-env    → secret de k8s en el cluster (lo patchea el deploy).
#   - LOCAL      → solo para `docker compose up` / correr a mano; no va a prod.
#
# Para LEVANTAR LOCAL solo necesitas `docker compose up --build -d`: el compose ya
# trae valores locales sanos embebidos (DB, JWT dev, seed admin). Este archivo
# documenta el set completo para PROD y para correr piezas sueltas a mano.
# ============================================================================


# ─────────────────────────────── BACKEND (API) ─────────────────────────────

# [REQ] Postgres del backend (TCP). LOCAL: el compose usa db:5432.
#       PROD: viene del provision de tofu dentro de app-env.
DATABASE_URL=postgres://mapa_app:localdev@localhost:5432/app

# [REC] Valkey/Redis para rate-limit compartido. Sin esto, cae a memoria (degradado).
VALKEY_URL=redis://localhost:6379

# [OPC] Entorno. development | production | test. La imagen fija production.
NODE_ENV=development
# [OPC] Puerto del backend.
PORT=8080

# --- Auth: superficie /admin (vieja, contraseña compartida) ---
# [REC] Contraseña del panel /admin (header x-admin-token). Comparación constante.
#       GH SECRET + app-env. Genera con: openssl rand -base64 12
ADMIN_PASSWORD=cambia-esta-contrasena

# --- Auth: motor RBAC api/public/* (JWT + roles + capacidades) ---
# [REQ en prod] Secreto de firma HS256 del JWT. >=32 chars o el server NO arranca
#       en producción. GH SECRET + app-env. Genera con: openssl rand -hex 32
JWT_SECRET=cambia-esto-min-32-caracteres-aleatorios-largos
# [OPC] Vida del access token (segundos). Default 12h.
JWT_TTL_SECONDS=43200
# [OPC] Nombre de la cookie httpOnly de sesión.
AUTH_COOKIE_NAME=mapa_session
# [REQ en prod] Cookie Secure (HTTPS). En prod DEBE ser true o el server no arranca.
#       LOCAL http: false. GH SECRET + app-env.
COOKIE_SECURE=false
# [REC] Base para los links de invitación/reset que arma el BACKEND. Debe ser el
#       PANEL ADMIN (ahí aterriza quien acepta: /invite/<token>), NO el sitio
#       público. Prod: https://admin.terremotovenezuela.app. GH SECRET + app-env.
APP_BASE_URL=http://localhost:3001
# [OPC] Caducidad de una invitación (horas).
INVITE_TTL_HOURS=72

# --- Superadmin semilla (lo crea el seed del Job migrate, idempotente) ---
# [REC] Email + contraseña del primer superadmin del motor RBAC. GH SECRET + app-env.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=cambia-esta-contrasena-admin

# --- SMTP (emails de invitación + reset de contraseña por OTP) ---
# [REC] Sin SMTP_HOST, el invite devuelve el link en la respuesta y el OTP se
#       loguea (modo dev). En prod configúralo. GH SECRET + app-env.
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=cambia-esta-contrasena-smtp
SMTP_FROM=Mapa Emergencia <noreply@example.com>

# --- Anti-bot, CORS, privacidad ---
# [REC] Cloudflare Turnstile (prueba de humanidad en writes públicos). Sin la
#       secret key, requireHuman se desactiva (dev). GH SECRET + app-env.
TURNSTILE_SECRET_KEY=cambia-esta-secret-de-turnstile
# [REQ] Orígenes del frontend permitidos por CORS (coma-separados). NO uses "*".
#       GH SECRET + app-env. Prod: https://terremotovenezuela.app
CORS_ORIGINS=http://localhost:3000
# [REC] Sal para hashear IPs antes de persistir (privacidad). Sin esto, hashIp lanza.
#       Genera con: openssl rand -hex 16
IP_SALT=cambia-esta-sal-de-ips
# [OPC] Cabecera de IP de confianza. Detrás de Cloudflare: cf-connecting-ip.
TRUSTED_IP_HEADER=cf-connecting-ip

# --- Cron / colas / analítica ---
# [OPC] Secreto para los endpoints de cron (Authorization: Bearer).
CRON_SECRET=cambia-esto-si-usas-cron
# [OPC] Prefijo y retención de colas BullMQ.
QUEUE_PREFIX=mapa
QUEUE_REMOVE_ON_COMPLETE=1000
QUEUE_REMOVE_ON_FAIL=5000
# [OPC] Proxy de analítica OpenPanel (server-side).
OPENPANEL_API_URL=https://api.openpanel.dev
OPENPANEL_CLIENT_SECRET=cambia-esto-si-usas-openpanel

# [OPC] Centros de acopio: el backend proxea ResponseGrid en /api/acopio (cache +
# rate-limit). Defaults sanos apuntan a la API pública y a la emergencia del
# terremoto de Venezuela; cámbialos para apuntar a otra instancia/emergencia.
RESPONSEGRID_API_URL=https://api.responsegrid.app
RESPONSEGRID_EMERGENCY_SLUG=terremoto-venezuela-2026

# ─────────────────── WORKER (sync / geocode / hub / backfill) ───────────────
# Casi todo tiene defaults sanos en código. Lo relevante para PROD:

# [REC] Scraping/sync de fuentes externas. 0 = APAGADO (intención actual en prod).
SYNC_SCHEDULERS=0
# [REC] Federación HUB. 0 = APAGADO.
HUB_SCHEDULERS=0
# [OPC] Sismos USGS (Venezuela). El scheduler SIEMPRE corre (no va bajo
# SYNC_SCHEDULERS): dato público y barato. Cadencia del sync incremental del feed
# realtime (default 60s = el feed USGS se refresca cada minuto). Backfill de
# arranque (días) si la tabla está vacía → siembra sola en el primer deploy. El
# bounding box de Venezuela tiene defaults sanos; solo override para ampliar.
EARTHQUAKES_EVERY_MS=60000
EARTHQUAKES_BACKFILL_DAYS=30
# EARTHQUAKES_FEED_PATH=/earthquakes/feed/v1.0/summary/2.5_week.geojson
# EARTHQUAKES_MIN_LAT=0.6
# EARTHQUAKES_MAX_LAT=12.2
# EARTHQUAKES_MIN_LNG=-73.4
# EARTHQUAKES_MAX_LNG=-59.8
# [OPC] Carpeta de migraciones (el Job migrate la apunta un nivel arriba).
MIGRATIONS_DIR=../infra/db/migrations
# [OPC] Backfill one-time Neon→Hetzner (solo el worker de migración lo necesita).
NEON_DATABASE_URL=
# (El resto de tuning del worker — HUB_*, PHOTO_*, *_CONCURRENCY, MIGRATE_*_TIMEOUT_MS,
#  SOURCE_*_URL, etc. — tiene defaults; sobre-escríbelo solo si sabes lo que haces.)

# [OPC, SOLO TESTS] Desactiva rate-limit en la suite de tests. NUNCA en prod.
# RATE_LIMIT_DISABLED=1


# ─────────────────────── FRONTEND (Next.js, NEXT_PUBLIC_*) ──────────────────
# Se INLINEAN en build (build-args del Dockerfile). En CI son GH VARIABLES
# (no secretos): NEXT_PUBLIC_API_URL, NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST,
# NEXT_PUBLIC_R2_PUBLIC_BASE, NEXT_PUBLIC_ASSET_PREFIX, etc.

# [REQ] URL ABSOLUTA del backend para el BROWSER. Prod: https://api.terremotovenezuela.app
NEXT_PUBLIC_API_URL=http://localhost:8080
# [OPC] URL del backend para SSR/Server Components DENTRO de Docker (red interna).
#       Sin esto, el fetch SSR cae a localhost dentro del contenedor y falla.
INTERNAL_API_URL=http://backend:8080
# [REC] Base pública del CDN R2 de fotos (no sensible).
NEXT_PUBLIC_R2_PUBLIC_BASE=https://bucket-vzla-terremoto.dreamit.software
# [REC] Site key pública de Turnstile (el widget). Pareja de TURNSTILE_SECRET_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=cambia-esta-site-key-de-turnstile
# [REC] Mismo valor que arriba pero con el nombre que usa el GH SECRET / build-arg
#       del workflow (se pasa como NEXT_PUBLIC_TURNSTILE_SITE_KEY al construir).
TURNSTILE_SITE_KEY=cambia-esta-site-key-de-turnstile
# [OPC] Prefijo CDN para /_next/static (R2). Sin setear → assets servidos por la app.
NEXT_PUBLIC_ASSET_PREFIX=
# [OPC] OpenPanel (analítica) — cliente público.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST=
NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL=


# ───────────────────────── INFRA / DEPLOY (CI + tofu) ───────────────────────
# Todo esto es GH SECRET (lo usa deploy-hetzner.yml) o lo lee tofu como TF_VAR_*.
# En local NO hace falta salvo que provisiones/despliegues a mano.

# [REQ deploy] Kubeconfig del cluster (base64). GH SECRET.
KUBECONFIG=
# [REQ deploy] GHCR pull (imágenes privadas). GH SECRET.
GHCR_PULL_USER=
GHCR_PULL_TOKEN=
TOKEN_GITHUB_PACKAGES=
# [REQ tofu] Hetzner Cloud API token (Read & Write). GH SECRET / TF_VAR_hcloud_token.
# El backend lo REUSA para gestionar el firewall del hub (réplica pública, RFC
# 0006): abrir/cerrar la IP de un consumidor en mapa-hub-fw. Idealmente, en prod,
# un token aparte SCOPED a firewalls. Si falta, la gestión de réplica queda OFF.
HCLOUD_TOKEN=

# --- Réplica pública (hub SQL, RFC 0006). OPCIONALES: si faltan, el backend
# responde 503 en /api/public/hub-credentials (resto del backend intacto). ---
# Conexión privada del rol CREATEROLE del backend al hub (output tofu hub_admin_url).
HUB_ADMIN_DATABASE_URL=
# Host PÚBLICO del hub que se entrega al consumidor (DNS → output hub_public_ip).
HUB_PUBLIC_HOST=data.terremotovenezuela.app
HUB_DB_NAME=public_db
# id numérico del firewall mapa-hub-fw (tofu state show hcloud_firewall.hub).
HUB_FIREWALL_ID=
# [REQ tofu] Token de join de k3s (master/workers/autoscaler). GH SECRET / TF_VAR_k3s_token.
K3S_TOKEN=
# [REQ tofu] Credenciales Postgres/Valkey del provision. TF_VAR_*.
POSTGRES_USER=mapa_app
POSTGRES_PASSWORD=cambia-esta-contrasena-de-postgres
POSTGRES_APP_DB=app
POSTGRES_IMPORTED_DB=imported
VALKEY_PASSWORD=cambia-esta-contrasena-de-valkey
# [OPC] Driver de DB (tcp para Hetzner).
DB_DRIVER=tcp
# [OPC] Hostname público de prod.
PROD_HOST=terremotovenezuela.app

# --- SSH (provision + recuperación) ---
# [REQ tofu] Clave SSH ops registrada en los servers. Pública inline; privada @path.
#       GH SECRET (SSH_PRIVATE_KEY / SSH_PUBLIC_KEY) / TF_VAR_ssh_public_key.
SSH_PUBLIC_KEY=ssh-ed25519 AAAA... tu-clave-ops
SSH_PRIVATE_KEY=@/home/USUARIO/.ssh/mapa_k3s
# [REC] Clave SSH break-glass (de respaldo, PRIVADA va OFFLINE). Solo la PUBKEY aquí.
#       TF_VAR_user_ssh_key. Vacío = desactivada.
user_ssh_key=ssh-ed25519 AAAA... tu-clave-breakglass

# --- R2 / Object Storage (fotos + assets estáticos + tofu state) ---
# [REC] R2 (Cloudflare) para fotos rehosteadas + /_next/static. GH SECRET.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_STATIC_BUCKET=
R2_PUBLIC_BASE=https://bucket-vzla-terremoto.dreamit.software
# [REQ tofu state] Hetzner Object Storage (S3) para el state de tofu. GH SECRET.
HETZNER_S3_ENDPOINT=
HETZNER_S3_ACCESS_KEY=
HETZNER_S3_SECRET_KEY=
HETZNER_S3_NAME=
HETZNER_S3_REGION=hel1


# ─────────────────────── PANEL ADMIN (admin/, 3er tier) ─────────────────────
# Microservicio Next standalone (admin.terremotovenezuela.app). El navegador
# habla SOLO con su BFF same-origin; el BFF llama al backend server-side. NO usa
# DB/Valkey/Turnstile (no hereda app-env). Estos valores los fija el Deployment
# (infra/k8s/deployment.yaml) en prod; aquí van para correrlo a mano / en compose.

# [REQ] URL del backend para el BFF del admin (server-to-server). En el clúster
#       usa la red INTERNA (no el dominio público): más rápido, sin salir a
#       Cloudflare. Prod (k8s): http://api.mapa.svc.cluster.local
#       Local (compose): http://backend:8080
EMERGENCY_API_URL=http://backend:8080
# [REQ en prod] Cookie de sesión del panel Secure (HTTPS). Local http: false.
COOKIE_SECURE=false
# [OPC] Vida de la cookie de sesión del panel (segundos). Default 12h. Espeja
#       JWT_TTL_SECONDS del backend.
SESSION_MAX_AGE_SECONDS=43200
# [OPC] API de insumos (aún no usada por ninguna ruta).
SUPPLIES_API_URL=
# [OPC] Prefijo CDN de los estáticos del panel. En CI se DERIVA solo de
#       NEXT_PUBLIC_R2_PUBLIC_BASE + "/admin" (no hace falta setearlo). Útil solo
#       para forzar un prefijo distinto al correr el build a mano.
NEXT_PUBLIC_ADMIN_ASSET_PREFIX=
# [REC, solo prod via .env del laptop] Base pública del panel para que el BACKEND
#       arme los links de invitación. En compose ya se inyecta como APP_BASE_URL
#       del backend. Prod: https://admin.terremotovenezuela.app
ADMIN_BASE_URL=https://admin.terremotovenezuela.app
