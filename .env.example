# ============================================================================
# .env.example — contrato de entorno del monorepo (frontend + backend + worker).
#
# Arquitectura tras el split:
#   - frontend/  Next (pura UI). Solo NEXT_PUBLIC_* (se INLINEAN en BUILD).
#   - backend/   Express API + worker BullMQ. Vars de runtime de servidor.
#
# En LOCAL: docker-compose.yml ya inyecta los valores de dev (no necesitas .env
# para levantar el stack). Este archivo documenta el contrato para prod/k8s.
# En PROD: el frontend hornea NEXT_PUBLIC_* como build-args (workflow/Dockerfile);
# el backend lee las vars de servidor desde el Secret k8s `app-env` (+ migrate-env
# para el backfill one-time). Ver infra/k8s/secret.example.yaml.
#
# Leyenda:  [REQ]=obligatorio  [REC]=recomendado (degrada si falta)  [OPC]=opcional
# ============================================================================

# ----------------------------------------------------------------------------
# BACKEND (Express API + worker) — Secret k8s `app-env`
# ----------------------------------------------------------------------------

# [REQ] Postgres por TCP del VPS privado de Hetzner. El proyecto YA NO usa Neon.
# (Único var que el backend exige en arranque; si falta, el server NO levanta.)
DATABASE_URL=

# [REQ-PROD] Orígenes del frontend permitidos por CORS (coma-separados). El front
# llama al backend CROSS-ORIGIN (api.terremoto… → terremoto…); sin esto el browser
# BLOQUEA toda respuesta. Local: docker-compose ya pone http://localhost:3000.
CORS_ORIGINS=https://terremotovenezuela.app

# [REC] Valkey/Redis para el rate-limit (sliding-window atómico). Si falta, el
# rate-limit DEGRADA a memoria por-pod (spoofable entre pods). Incluye password.
#   redis://:<VALKEY_PASSWORD>@<valkey-private-ip>:6379
VALKEY_URL=

# [REC] Sal para hashear IPs antes de persistirlas (columnas ip_hash). Genera una
# cadena aleatoria larga (`openssl rand -hex 32`). hashIp LANZA si falta y se va a
# persistir una IP. NO la rotes sin migrar/backfill (rompe la dedup por IP).
IP_SALT=

# [REC-PROD] Cloudflare Turnstile: prueba de humanidad en writes públicos. SIN
# este secret, el middleware requireHuman se DESACTIVA (deja pasar bots) — que es
# justo lo que queremos evitar en prod. Además del secret aquí, el FRONTEND debe
# recibir el SITE key público (`NEXT_PUBLIC_TURNSTILE_SITE_KEY`) para renderizar
# el widget y enviar tokens frescos por submit.
TURNSTILE_SECRET_KEY=

# [REC] Auth del panel admin (header x-admin-token). Sin esto las rutas admin
# quedan cerradas (unauthorized).
ADMIN_PASSWORD=

# [OPC] Secreto para disparar crons/sync vía Authorization: Bearer.
CRON_SECRET=

# [OPC] Cabecera de IP de confianza. Detrás de Cloudflare DEBE ser cf-connecting-ip
# (el cliente NO la falsifica) — el backend ya usa ese default. NUNCA x-forwarded-for.
TRUSTED_IP_HEADER=cf-connecting-ip

# [OPC] Proxy de analítica OpenPanel (route /api/op). Default sano si se omite.
OPENPANEL_API_URL=https://api.openpanel.dev
OPENPANEL_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# WORKER / MIGRATE — Secret k8s `migrate-env` (solo el backfill one-time Neon→R2)
# El sync/HUB en curso usa `app-env`. Estos solo los necesita la migración inicial.
# ----------------------------------------------------------------------------

# [OPC] Origen Neon de la migración one-time de datos a Hetzner.
NEON_DATABASE_URL=

# [REC-PROD] Cloudflare R2 (fotos). El backend sube fotos nuevas a R2 y el route
# /photo redirige al CDN. Si NO están todas, cae al camino legado base64-en-DB.
R2_ENDPOINT=
R2_STATIC_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Base pública del CDN para construir las URLs servidas. Ej:
#   https://bucket-vzla-terremoto.dreamit.software
R2_PUBLIC_BASE=

# [OPC] Override de la carpeta de migraciones. En la imagen backend (WORKDIR
# /app/backend) los .sql viven un nivel arriba → el migrate-job pone esto.
# MIGRATIONS_DIR=../infra/db/migrations

# Nota: el worker acepta MUCHAS vars de tuning opcionales con defaults sanos
# (HUB_*, SYNC_*, PHOTO_*, *_CONCURRENCY, QUEUE_*, *_RATE_*). No hace falta
# setearlas; ver backend/worker/** para el detalle.

# ----------------------------------------------------------------------------
# FRONTEND (Next) — NEXT_PUBLIC_* se INLINEAN en BUILD (build-args), no en runtime.
# En prod se pasan como build-args en el workflow; como GitHub *Variables* idealmente.
# ----------------------------------------------------------------------------

# [REQ-PROD] URL ABSOLUTA del backend para el browser. El front llama por esta URL
# (no rutas relativas). Local: http://localhost:8080 (lo pone docker-compose).
#
# IMPORTANTE: este valor es el ORIGEN del backend, SIN `/api` al final. Las
# rutas que los componentes/hooks pasan a `apiGet`/`apiSend`/`apiFetch` ya
# empiezan con `/api/...`, así que la URL final compuesta queda como
# `https://api.terremotovenezuela.app/api/<ruta>`. No agregues `/api` aquí o
# terminarás con `/api/api/...`.
NEXT_PUBLIC_API_URL=https://api.terremotovenezuela.app

# [REC] Base pública del CDN de fotos (no sensible). Si se omite, las fotos siguen
# sirviéndose vía el redirect del backend (funciona, un salto extra).
NEXT_PUBLIC_R2_PUBLIC_BASE=https://bucket-vzla-terremoto.dreamit.software

# [REC-PROD] Site key público de Cloudflare Turnstile. En GitHub Actions se pasa
# como secret `TURNSTILE_SITE_KEY` y se inlinea como NEXT_PUBLIC_* en build.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# [OPC] CDN para /_next/static (R2 + Cloudflare). Sin setear → la app sirve assets.
NEXT_PUBLIC_ASSET_PREFIX=

# [OPC] OpenPanel (analítica). El client id viene del proyecto OpenPanel.
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=
NEXT_PUBLIC_OPENPANEL_DASHBOARD_URL=
NEXT_PUBLIC_OPENPANEL_PRODUCTION_HOST=terremotovenezuela.app

# [OPC] Enlaces de UI (si faltan, el bloque correspondiente queda oculto/vacío).
NEXT_PUBLIC_STRIPE_DONATION_URL=
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=
NEXT_PUBLIC_X_PROFILE_URL=
NEXT_PUBLIC_PSYCHOLOGY_HELP_URL=
NEXT_PUBLIC_EXPENSES_URL=
NEXT_PUBLIC_PROPOSAL_VARIANT=

# [OPC] SSR/Server Components: base interna para llamar al backend desde el server
# de Next (red de Docker/k8s), en vez de la URL pública. Default: NEXT_PUBLIC_API_URL.
INTERNAL_API_URL=
PATIENT_DOCUMENT_HASH_SECRET=replace-with-a-long-random-secret

# OCR/ICR de importación de pacientes (Minimax VL). Opcional: sin API key,
# la entrada image/* y PDF sigue rechazada con 501. No hardcodear tokens.
MINIMAX_API_KEY=
MINIMAX_OCR_BASE_URL=https://api.minimax.io/v1
MINIMAX_OCR_MODEL=MiniMax-M3
MINIMAX_OCR_MAX_TOKENS=2048
MINIMAX_OCR_TIMEOUT_MS=30000
MINIMAX_OCR_PROMPT=
