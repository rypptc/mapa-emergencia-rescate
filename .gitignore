# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# lockfiles de otros gestores: este repo usa npm (package-lock.json)
bun.lock
bun.lockb
yarn.lock
pnpm-lock.yaml

# testing
/coverage

# next.js
.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# `.env*` NO captura `.staging.env` (el punto va antes de "env"): ignorar explícito.
.staging.env
*.staging.env

# vercel
.vercel

# database backups
*.sql
*.dump
*.sql.gz
# ...pero las migraciones de Drizzle SÍ se versionan (son código, deben ir en la
# imagen para que el Job migrate las aplique).
!infra/db/migrations/*.sql

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts operativos locales (no forman parte de la app ni del build)
_*.mts

# bundles de diseño/referencia (capturas, mockups, exports) — no son parte de la app
Emergencia nacional de búsqueda/
Emergencia nacional de búsqueda.zip

.claude/commands/*
upload-github-secrets.sh
node_modules/