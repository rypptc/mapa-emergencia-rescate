{
  "name": "landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run endpoints:check && node --import tsx scripts/gen-openapi.mts",
    "build": "next build",
    "openapi": "node --import tsx scripts/gen-openapi.mts",
    "endpoints:check": "node scripts/check-endpoints.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "worker": "node --import tsx worker/index.ts",
    "migrate:enqueue": "node --import tsx worker/enqueue.ts",
    "migrate": "node --import tsx worker/migrate.ts",
    "hub:backfill": "node --import tsx worker/hub-backfill.ts",
    "db:generate": "drizzle-kit generate --config infra/db/drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.9",
    "@openpanel/nextjs": "^1.5.1",
    "@types/supercluster": "^7.1.3",
    "bullmq": "^5.67.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "5.10.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-swagger-doc": "^0.4.1",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "supercluster": "^8.0.1",
    "turbo-stream": "2.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js}": "eslint --fix"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
