# Example tfvars. In CI these come from TF_VAR_* env vars (GitHub secrets), so
# you usually DON'T need this file there. For a local `tofu plan`, copy to
# terraform.tfvars (gitignored) and fill in. NEVER commit real secrets.
hcloud_token         = "your-hcloud-read-write-token"
ssh_public_key       = "ssh-ed25519 AAAA... mapa-k3s-deploy"
postgres_user        = "mapa_app"
postgres_password    = "from openssl rand -hex 32"
valkey_password      = "from openssl rand -hex 32"

# Optional overrides (defaults shown):
# location             = "hel1"
# server_type          = "cx23"
# postgres_app_db      = "app"
# postgres_imported_db = "imported"
# postgres_volume_size = 40

# --- Hub Postgres (réplica pública saneada, RFC 0006) ---
hub_repl_password  = "from openssl rand -hex 32"
hub_admin_password = "from openssl rand -hex 32"
# Allowlists del firewall del hub. Vacío = cerrado a internet (replicación
# privada sigue OK). Agrega IPs de admin/consumidores cuando toque.
# hub_admin_ips    = ["TU.IP.ADMIN/32"]
# hub_consumer_ips = ["IP.DEL.CONSUMIDOR/32"]
# hub_private_ip      = "10.0.1.12"
# hub_db              = "public_db"
# hub_volume_size     = 40
# hub_consumer_pg_hba = "0.0.0.0/0"   # control de IP delegado al firewall
